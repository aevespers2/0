{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActionRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "mission_id",
    "step_id",
    "actor",
    "action_type",
    "status",
    "summary",
    "created_at"
  ],
  "properties": {
    "action_id": {
      "type": "string",
      "pattern": "^act-[A-Za-z0-9._-]+$"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^mission-[A-Za-z0-9._-]+$"
    },
    "step_id": {
      "type": "string",
      "pattern": "^step-[A-Za-z0-9._-]+$"
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "action_type": {
      "type": "string",
      "enum": ["plan", "check", "edit", "report", "policy_decision"]
    },
    "command": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "blocked", "skipped"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "details": {
      "type": "object"
    }
  }
}
