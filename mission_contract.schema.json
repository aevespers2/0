{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/mission_contract.schema.json",
  "title": "MissionContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "scope",
    "constraints",
    "acceptance_criteria",
    "risk_tolerance"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "risk_tolerance": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  }
}
