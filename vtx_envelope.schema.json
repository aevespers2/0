{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aevespers.local/schemas/vtx_envelope.schema.json",
  "title": "Verification Transport Exchange Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "envelope_id",
    "issued_at",
    "expires_at",
    "nonce",
    "issuer",
    "repository",
    "operation",
    "target",
    "payload_digest",
    "policy_id"
  ],
  "properties": {
    "version": {"const": "vtx.envelope.v1"},
    "envelope_id": {"type": "string", "minLength": 16, "maxLength": 128},
    "issued_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "nonce": {"type": "string", "minLength": 16, "maxLength": 256},
    "issuer": {"type": "string", "minLength": 1, "maxLength": 256},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "repository_id", "state_digest"],
      "properties": {
        "authority": {"enum": ["private"]},
        "repository_id": {"type": "string", "minLength": 1, "maxLength": 512},
        "state_digest": {"type": "string", "pattern": "^(sha256|blake3):[0-9a-f]{64}$"}
      }
    },
    "operation": {
      "enum": [
        "github.push",
        "github.release",
        "github.workflow_dispatch",
        "github.issue_mutation",
        "github.pull_request",
        "github.webhook_proposal"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "repository"],
      "properties": {
        "provider": {"const": "github"},
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "ref": {"type": "string", "maxLength": 512},
        "workflow": {"type": "string", "maxLength": 512}
      }
    },
    "payload_digest": {"type": "string", "pattern": "^(sha256|blake3):[0-9a-f]{64}$"},
    "policy_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "claims": {"type": "object"},
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": {"enum": ["ed25519"]},
        "key_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "value": {"type": "string", "minLength": 32}
      }
    }
  }
}
